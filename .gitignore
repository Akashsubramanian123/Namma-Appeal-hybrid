# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
lib/secrets.dart 
# ==========================================
# EXTRA PRODUCTION SAFEGUARDS
# ==========================================

# Android Release Signing (CRITICAL: Never upload your app signature keys!)
*.jks
*.keystore
key.properties
android/key.properties

# iOS/macOS CocoaPods dependencies (These get auto-generated, no need to upload them)
**/ios/Pods/
**/macos/Pods/
.symlinks/

# Desktop ephemeral build files
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/
**/macos/Flutter/ephemeral/

# Environment variables (Just in case you use .env files later)
.env
.env.*